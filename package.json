{
  "name": "jarvis",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "apps/desktop/e2e",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @jarvis/desktop run dev",
    "build": "npm --workspace @jarvis/desktop run build",
    "preview": "npm --workspace @jarvis/desktop run preview",
    "tauri": "tauri dev --config apps/desktop/src-tauri/tauri.conf.json",
    "tauri:build": "npm run tauri:build --workspace @jarvis/desktop",
    "typecheck": "npm exec tsc --noEmit && npm --workspace @jarvis/types run typecheck",
    "e2e:ui": "npm --workspace @jarvis/desktop-e2e test",
    "e2e:api": "node scripts/e2e/run-api-smoke.mjs",
    "e2e:api:service": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/e2e/run-api-service-smoke.ps1",
    "e2e:desktop": "node scripts/e2e/run-desktop-smoke.mjs",
    "e2e:smoke:check": "node --check scripts/e2e/run-api-smoke.mjs && node --check scripts/e2e/run-desktop-smoke.mjs",
    "e2e:smoke:check:windows": "powershell -NoProfile -Command \"[void][scriptblock]::Create((Get-Content -Raw 'scripts/e2e/run-api-service-smoke.ps1')); [void][scriptblock]::Create((Get-Content -Raw 'scripts/e2e/smoke-local-api.ps1')); Write-Host 'PowerShell smoke wrappers parsed successfully.'\"",
    "verify": "npm run build --workspace @jarvis/desktop && npm run e2e:smoke:check && npm run e2e:ui",
    "verify:api": "npm run e2e:api:service",
    "verify:full": "npm run verify && npm run verify:api",
    "dev:desktop": "npm --workspace @jarvis/desktop run dev",
    "build:desktop": "npm --workspace @jarvis/desktop run build",
    "tauri:desktop": "npm run tauri",
    "clean:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-build-artifacts.ps1",
    "setup:lean-dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-lean-dev.ps1"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@tauri-apps/api": "^2.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.6.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
