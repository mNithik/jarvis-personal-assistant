{
  "name": "jarvis",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @jarvis/desktop run dev",
    "build": "npm --workspace @jarvis/desktop run build",
    "preview": "npm --workspace @jarvis/desktop run preview",
    "tauri": "tauri dev --config apps/desktop/src-tauri/tauri.conf.json",
    "tauri:build": "npm run tauri:build --workspace @jarvis/desktop",
    "typecheck": "npm exec tsc --noEmit && npm --workspace @jarvis/types run typecheck",
    "dev:desktop": "npm --workspace @jarvis/desktop run dev",
    "build:desktop": "npm --workspace @jarvis/desktop run build",
    "tauri:desktop": "npm run tauri",
    "clean:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-build-artifacts.ps1",
    "setup:lean-dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-lean-dev.ps1"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@tauri-apps/api": "^2.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.6.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
