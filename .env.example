# JARVIS local secrets — copy this file to `.env` and fill in keys as you go.
# `.env` is gitignored. Env vars here override Windows Credential Manager at runtime.

# --- Model providers (Wave D+ gateway / talker / escalation) ---
JARVIS_GROQ_API_KEY=
JARVIS_OPENROUTER_API_KEY=
JARVIS_NVIDIA_NIM_API_KEY=
JARVIS_GEMINI_API_KEY=
JARVIS_OPENAI_API_KEY=
JARVIS_ANTHROPIC_API_KEY=
JARVIS_HUGGINGFACE_API_KEY=

# --- Common aliases (optional; JARVIS_* names are preferred) ---
# GROQ_API_KEY=
# NVIDIA_API_KEY=
# OPENAI_API_KEY=

# --- Integrations (Wave E+ / App.tsx) ---
JARVIS_NOTION_TOKEN=
JARVIS_SPOTIFY_CLIENT_ID=
JARVIS_GOOGLE_CLIENT_ID=
JARVIS_GITHUB_TOKEN=
JARVIS_GITHUB_DEFAULT_REPO=
# GITHUB_PERSONAL_ACCESS_TOKEN=   # alias used by GitHub MCP server

# --- Local inference (no key usually needed) ---
JARVIS_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
JARVIS_LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1

# --- Builder embedded terminal (Wave 14-T) ---
# Set to 0 to disable auto handoff launch into the embedded terminal
JARVIS_EMBEDDED_TERMINAL=1
