{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JARVIS",
  "version": "0.1.0",
  "identifier": "com.nithi.jarvis",
  "build": {
    "beforeDevCommand": "npm --workspace @jarvis/desktop run dev",
    "beforeBuildCommand": "npm --workspace @jarvis/desktop run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "JARVIS",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
